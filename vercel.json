{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/python/:path*",
      "destination": "/_backend/api/:path*"
    }
  ]
}
